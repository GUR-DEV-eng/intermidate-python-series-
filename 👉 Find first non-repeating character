# Problem: Find first non-repeating character
# Example: "aabbcde" → "c"

def first_non_repeating_char(s: str) -> str:
    char_count = {}
    
    # Count frequency
    for ch in s:
        char_count[ch] = char_count.get(ch, 0) + 1
    
    # Find first unique character
    for ch in s:
        if char_count[ch] == 1:
            return ch
    
    return ""

# Test
print(first_non_repeating_char("aabbcde"))  # Output: c
